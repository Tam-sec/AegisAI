# ─── Database ───
DATABASE_URL=sqlite:///./data/hr_app.db
# For PostgreSQL (Docker): DATABASE_URL=postgresql://hr_user:hr_pass@localhost:5432/hr_db

# ─── Ollama AI ───
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:latest
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=120

# ─── Security ───
SECRET_KEY=dev-secret-key-change-in-production-please-1234567890abcdef
ENCRYPTION_KEY=ZGV2LWVuY3J5cHRpb24ta2V5LTMyYnl0ZXM=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ─── App ───
APP_ENV=development
CORS_ORIGINS=http://localhost:3000
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=25
DATA_RETENTION_DAYS=365

# ─── Frontend ───
NEXT_PUBLIC_API_URL=http://localhost:8001
